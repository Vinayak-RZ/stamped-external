{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stamped.energy/schemas/ledger-entry.v1.json",
  "title": "LedgerEntry",
  "description": "L5 → L2/L6 savings ledger record. Append-only in L2. P0 uses ops_confirmed for telemetry clearance; verified reserved for deferred bill path. See ADR-020.",
  "type": "object",
  "required": [
    "schema_version",
    "entry_id",
    "org_id",
    "plant_id",
    "prescription_id",
    "entry_type",
    "period_start",
    "period_end",
    "potential_kwh",
    "realised_kwh",
    "potential_inr",
    "realised_inr",
    "mv_method",
    "baseline_id",
    "verification_status",
    "dedupe_key"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "const": "1.0.0"
    },
    "entry_id": { "type": "string", "minLength": 1 },
    "org_id": { "type": "string", "minLength": 1 },
    "plant_id": { "type": "string", "minLength": 1 },
    "prescription_id": { "type": "string", "minLength": 1 },
    "entry_type": {
      "type": "string",
      "enum": ["realised_savings", "potential_savings", "opportunity_cost"],
      "description": "opportunity_cost = counterfactual delay cost (ADR-013)"
    },
    "period_start": { "type": "string", "format": "date-time" },
    "period_end": { "type": "string", "format": "date-time" },
    "potential_kwh": { "type": "number", "minimum": 0 },
    "realised_kwh": { "type": "number", "minimum": 0 },
    "potential_inr": { "type": "number", "minimum": 0 },
    "realised_inr": { "type": "number", "minimum": 0 },
    "avoided_tco2e": { "type": "number", "minimum": 0 },
    "mv_method": { "type": "string" },
    "baseline_id": { "type": "string" },
    "bill_line_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "intensity_delta": { "type": ["number", "null"] },
    "verification_status": {
      "type": "string",
      "enum": ["pending", "ops_confirmed", "verified", "disputed", "modeled"],
      "description": "ops_confirmed = telemetry clearance (P0). verified = reserved for future bill path. modeled = counterfactual/non-ops."
    },
    "modeled_reason": {
      "type": "string",
      "description": "Required when verification_status=modeled (e.g. opportunity_cost)"
    },
    "delay_days": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "For opportunity_cost entries"
    },
    "supersedes_entry_id": {
      "type": ["string", "null"],
      "description": "When set, this row corrects/reverses a prior LedgerEntry; prior row remains immutable"
    },
    "emission_factor_ref": {
      "type": ["string", "null"],
      "description": "Versioned emission factor id used when avoided_tco2e was computed"
    },
    "dedupe_key": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "additionalProperties": false
}
