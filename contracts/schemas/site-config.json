{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stamped.energy/schemas/site-config.v1.json",
  "title": "SiteConfig",
  "type": "object",
  "required": ["schema_version", "plant_id", "org_id", "timezone", "connectors", "uplink", "buffer"],
  "properties": {
    "schema_version": { "type": "string" },
    "plant_id": { "type": "string" },
    "org_id": { "type": "string" },
    "timezone": { "type": "string" },
    "connectors": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "array", "items": { "type": "string" } },
        "modbus": { "type": "array" },
        "mqtt": { "type": "array" },
        "filewatch": { "type": "array" },
        "opcua": { "type": "array" },
        "historian": { "type": "array" },
        "rest_poller": { "type": "array" },
        "dlms": { "type": "array" }
      }
    },
    "uplink": {
      "type": "object",
      "required": ["broker_url"],
      "properties": {
        "broker_url": { "type": "string" },
        "client_cert_path": { "type": "string" },
        "client_key_path": { "type": "string" },
        "ca_path": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "manifest_url": { "type": "string" },
        "poll_interval_s": { "type": "integer", "minimum": 1 }
      }
    },
    "mapping": {
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "path": { "type": "string" }
      }
    },
    "buffer": {
      "type": "object",
      "required": ["path", "retention_hours"],
      "properties": {
        "path": { "type": "string" },
        "retention_hours": { "type": "integer", "minimum": 1 }
      }
    },
    "harvest": {
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "interval_s": { "type": "integer", "minimum": 1 },
        "warmup_s": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
