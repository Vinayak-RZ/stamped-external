{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stamped.energy/schemas/rule-file.v1.json",
  "title": "RuleFile",
  "type": "object",
  "required": ["id", "category", "engine", "version", "waste_category", "formula_ref"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "engine": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "waste_category": { "type": "integer", "minimum": 1, "maximum": 6 },
    "formula_ref": { "type": "string", "minLength": 1 },
    "metric": { "type": "string" },
    "defaults": { "type": "object" },
    "suppressions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "threshold_kva": { "type": "number" },
    "baseline_band": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 2,
      "maxItems": 2
    }
  },
  "additionalProperties": true
}
